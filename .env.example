# Environment Configuration for Frontal MCP Server

# Required: Your Frontal API key
FRONTAL_API_KEY=frt_your_api_key_here

# Optional: Frontal API base URL (defaults to https://api.frontal.dev/v1)
FRONTAL_BASE_URL=https://api.frontal.dev/v1

# Optional: Server configuration
MCP_SERVER_PORT=3000
MCP_SERVER_HOST=localhost
MCP_LOG_LEVEL=info

# Optional: Enable specific services (all enabled by default)
ENABLE_AI=true
ENABLE_BLOB=true
ENABLE_FUNCTIONS=true
ENABLE_GRAPH=true
ENABLE_PIPELINES=true

# Optional: Authentication
AUTH_TYPE=api-key
# AUTH_TYPE=oauth

# Development
NODE_ENV=development
