# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Source files
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Configuration files
*.toml text eol=lf
.*rc text eol=lf
.*ignore text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary

# Generated files
*.tgz binary
*.tar binary
*.zip binary

# Lock files
bun.lock text
package-lock.json text
yarn.lock text
pnpm-lock.yaml text
