{
  "name": "@frontal/mcp-server",
  "version": "1.0.0",
  "description": "Model Context Protocol server for Frontal services",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "frontal-mcp-server": "dist/bin/frontal-mcp-server.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup && node -e \"const fs=require('fs');const f='dist/bin/frontal-mcp-server.js';const c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!'))fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c)\"",
    "build:watch": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome lint src/ tests/",
    "format": "biome format --write src/ tests/",
    "clean": "rm -rf dist",
    "dev": "bun run src/bin/frontal-mcp-server.ts",
    "prepublishOnly": "bun run build",
    "prepare": "husky",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run build && changeset publish",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "frontal",
    "frontal-cloud",
    "ai",
    "serverless",
    "blob-storage",
    "functions",
    "typescript"
  ],
  "homepage": "https://github.com/frontal-cloud/mcp-server",
  "bugs": "https://github.com/frontal-cloud/mcp-server/issues",
  "license": "MIT",
  "author": "Frontal Labs",
  "repository": {
    "type": "git",
    "url": "https://github.com/frontal-cloud/mcp-server.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.3.8"
  },
  "packageManager": "bun@1.3.8",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@t3-oss/env-core": "^0.13.11",
    "chalk": "^5.4.0",
    "commander": "^14.0.3",
    "ora": "^8.2.0",
    "tslib": "^2.8.1",
    "winston": "^3.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^2.1.8",
    "husky": "^9.1.7",
    "tsup": "^8.0.0",
    "typescript": "^5.7.3",
    "ultracite": "7.4.0",
    "vitest": "^2.1.8"
  }
}
