# Environment Configuration for Frontal MCP Server

# Required: Your Frontal API key
FRONTAL_API_KEY=frt_your_api_key_here

# Optional: Frontal API base URL (defaults to https://api.frontal.dev/v1)
FRONTAL_BASE_URL=https://api.frontal.dev/v1

# Optional: Server configuration
MCP_SERVER_PORT=3000
MCP_SERVER_HOST=localhost
MCP_LOG_LEVEL=info

# Optional: incident.io status page integration (auto-activates when API key is set)
# INCIDENTIO_API_KEY=inc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# INCIDENTIO_STATUS_PAGE_ID=01H0QJ1BXP0E76RGBYRDHKA2KQ
# INCIDENTIO_STATUS_PAGE_URL=https://frontal-status.com
# INCIDENTIO_COMPONENT_ID=01H0QJ1BXP0E76RGBYRDHKA2KB

# Optional: Authentication
AUTH_TYPE=api-key
# AUTH_TYPE=oauth

# Development
NODE_ENV=development
